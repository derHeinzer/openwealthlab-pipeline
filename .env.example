# === Trade Republic ===
TR_PHONE_NUMBER=+49...
TR_PIN=1234

# === Google / Firestore ===
# Service Account JSON (single line or file path)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# === GitHub (for pushing markdown stubs) ===
OWL_GITHUB_TOKEN=ghp_...

# === OpenFIGI (optional — higher rate limits with key) ===
OPENFIGI_API_KEY=

# === Pipeline settings ===
# "prod" or "dev" — controls Firestore collection name
PIPELINE_ENV=dev
